@* NavMenu.razor
   Sidebar navigation — two links: New Entry and View Records.
   The navbar-toggler checkbox is a CSS-only mobile toggle (no JavaScript needed). *@

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Timezone Manager</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="new-entry">
                <span class="bi bi-new-entry-icon" aria-hidden="true"></span> New Entry
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="records">
                <span class="bi bi-records-icon" aria-hidden="true"></span> View Records
            </NavLink>
        </div>
    </nav>
</div>
